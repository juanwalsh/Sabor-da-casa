# Configurações de Ambiente (EP LOPES)

# -----------------------------------------------------------------------------
# AUTENTICAÇÃO E SEGURANÇA (CRÍTICO - OBRIGATÓRIO EM PRODUÇÃO)
# -----------------------------------------------------------------------------

# Senha do administrador (case-sensitive)
ADMIN_PASSWORD=SuaSenhaForteAqui123!

# Chave secreta para assinatura de JWT. Use um hash longo e aleatório.
# Gere com: openssl rand -base64 32
JWT_SECRET=ChaveSuperSecretaDoJWT_MudeIssoEmProducao

# -----------------------------------------------------------------------------
# FIREBASE (BANCO DE DADOS E AUTH)
# -----------------------------------------------------------------------------
# Obtenha estas chaves no Console do Firebase > Project Settings

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# -----------------------------------------------------------------------------
# RATE LIMITING (UPSTASH REDIS)
# -----------------------------------------------------------------------------
# Crie um banco Redis em https://upstash.com/
# Se não configurado, o Rate Limit será ignorado (bom para dev, ruim para prod)

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=